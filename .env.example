SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Required on Railway for Socket Mode (xapp-…, scope connections:write). If empty, Bolt uses HTTP /slack/events only.
# Set on the Railway *service* (shared vars must be linked). Aliases: SLACK_SOCKET_APP_TOKEN, SLACK_XAPP_TOKEN.
SLACK_APP_TOKEN=

DB_PATH=./snipe-elo.sqlite3

# ELO config
ELO_K_FACTOR=32
INITIAL_RATING=1000

# Canvas leaderboard config
LEADERBOARD_CANVAS_TITLE=ELO Leaderboard
LEADERBOARD_TOP_N=50
# Strongly recommended on Railway: set after first canvas exists so redeploys never create another.
# LEADERBOARD_CANVAS_ID=F1234567890

# Implicit snipe: require image in same message as mentions (default true).
# Set to false to count @mentions alone as a snipe (no photo).
# SNIPE_REQUIRE_IMAGE=true

# Slash command names (register the same commands in the Slack app → Slash Commands; Request URL = your Bolt URL, usually /slack/events)
UNDO_COMMAND=/removesnipe
MAKEUP_COMMAND=/makeupsnipe
# ADJUSTELO_COMMAND=/adjustelo
# Comma-separated Slack user IDs allowed to run /adjustelo (default: U09E6EHA5R8)
# ADJUSTELO_ALLOWED_SLACK_USER_IDS=U09E6EHA5R8
# SLACK_LEADERBOARD_COMMAND=/leaderboard
# SLACK_SHOW_LEADERBOARD_COMMAND=/show_leaderboard
# SLACK_SNIPES_COMMAND=/snipes
# SLACK_HEADTOHEAD_COMMAND=/headtohead
# SLACK_HELP_COMMAND=/help
# SLACK_SNIPEDUEL_COMMAND=/snipeduel

# Undo in a snipe thread: type plain `removesnipe` (Slack blocks /slash in threads)—always on, no env.
# If slash commands never appear in Slack, set this for other plain-text commands in-channel:
# leaderboard | makeupsnipe … | adjustelo …
# SLACK_TEXT_COMMANDS_FALLBACK=true

PORT=3000

