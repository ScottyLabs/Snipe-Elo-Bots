SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Required on Railway for Socket Mode (xapp-…). If empty, Bolt uses HTTP /slack/events only.
# Must be set in Railway Variables (repo .env is not used in production — dotenv "0 vars" is normal).
SLACK_APP_TOKEN=

DB_PATH=./snipe-elo.sqlite3

# ELO config
ELO_K_FACTOR=32
INITIAL_RATING=1000

# Canvas leaderboard config
LEADERBOARD_CANVAS_TITLE=ELO Leaderboard
LEADERBOARD_TOP_N=50
# Strongly recommended on Railway: set after first canvas exists so redeploys never create another.
# LEADERBOARD_CANVAS_ID=F1234567890

# Implicit snipe: require image in same message as mentions (default true).
# Set to false to count @mentions alone as a snipe (no photo).
# SNIPE_REQUIRE_IMAGE=true

# Commands
UNDO_COMMAND=removesnipe
MAKEUP_COMMAND=makeupsnipe

PORT=3000

