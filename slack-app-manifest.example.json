{
  "display_information": {
    "name": "Snipe ELO",
    "description": "Example Slack app manifest — import at https://api.slack.com/apps → Create New App → From an app manifest. Replace placeholder URLs if you use HTTP mode; with Socket Mode they are often ignored for delivery.",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "Snipe ELO",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/leaderboard",
        "url": "https://example.com/slack/events",
        "description": "Show ELO leaderboard in channel",
        "should_escape": false
      },
      {
        "command": "/show_leaderboard",
        "url": "https://example.com/slack/events",
        "description": "Show ELO leaderboard (alias of /leaderboard)",
        "should_escape": false
      },
      {
        "command": "/removesnipe",
        "url": "https://example.com/slack/events",
        "description": "Undo last snipe in this thread",
        "should_escape": false
      },
      {
        "command": "/makeupsnipe",
        "url": "https://example.com/slack/events",
        "description": "Record a makeup snipe",
        "usage_hint": "[sniper] [sniped…] as mentions",
        "should_escape": false
      },
      {
        "command": "/adjustelo",
        "url": "https://example.com/slack/events",
        "description": "Manually adjust ELO (authorized users only)",
        "usage_hint": "[user mention] [delta]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "chat:write",
        "reactions:write",
        "users:read",
        "canvases:read",
        "canvases:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://example.com/slack/events",
      "bot_events": ["message.channels"]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://example.com/slack/events"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
